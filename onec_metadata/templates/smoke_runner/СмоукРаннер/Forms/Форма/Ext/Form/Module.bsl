// СмоукРаннер (toolkit, обезличенный) — ступень 2 лестницы тестирования.
// Запуск: 1cv8 ENTERPRISE /Execute СмоукРаннер.epf /C"<сценарий.bsl>;<результат.txt>"
// Сценарий — серверный BSL; строковая переменная Отчет из сценария попадает
// в файл-результат после маркера __SMOKE_OK__. Любое исключение —
// __SMOKE_FAIL__ + подробности. Вердикт ТОЛЬКО по файлу-результату.
//
// ФАЙЛЫ ЧИТАЕТ И ПИШЕТ КЛИЕНТ, на сервер уходит только ТЕКСТ сценария.
// Иначе на клиент-серверной базе серверный код исполняется в rphost на машине
// кластера, где локальных путей разработчика нет: платформа уходит в бесконечный
// getServerFileHost → IFolderFileHost::open, сеанс висит вечно, без окна и без
// единой строки в /Out. На файловой базе разницы не видно — там клиент и сервер
// одна машина, поэтому дефект и жил незамеченным (боевой разбор 23.07 по ТЖ).

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ПодключитьОбработчикОжидания("Ткт_ВыполнитьСмоук", 0.1, Истина);
КонецПроцедуры

&НаКлиенте
Процедура Ткт_ВыполнитьСмоук()

	Части = СтрРазделить(ПараметрЗапуска, ";", Ложь);
	Если Части.Количество() < 2 Тогда
		ЗавершитьРаботуСистемы(Ложь); // без файла результата писать некуда
		Возврат;
	КонецЕсли;
	ФайлСценария   = СокрЛП(Части[0]);
	ФайлРезультата = СокрЛП(Части[1]);

	Попытка
		Чтение = Новый ЧтениеТекста(ФайлСценария, КодировкаТекста.UTF8);
		ТекстСценария = Чтение.Прочитать();
		Чтение.Закрыть();
	Исключение
		ЗаписатьРезультат(ФайлРезультата, "__SMOKE_FAIL__",
			"не прочитан файл сценария " + ФайлСценария + ": "
			+ ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗавершитьРаботуСистемы(Ложь);
		Возврат;
	КонецПопытки;

	Итог = ВыполнитьСмоукНаСервере(ТекстСценария);
	ЗаписатьРезультат(ФайлРезультата, Итог.Маркер, Итог.Текст);
	ЗавершитьРаботуСистемы(Ложь);

КонецПроцедуры

&НаСервереБезКонтекста
Функция ВыполнитьСмоукНаСервере(Знач ТекстСценария)

	Отчет = "";
	Попытка
		Выполнить(ТекстСценария);
		Возврат Новый Структура("Маркер, Текст", "__SMOKE_OK__", Отчет);
	Исключение
		Возврат Новый Структура("Маркер, Текст", "__SMOKE_FAIL__",
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;

КонецФункции

&НаКлиенте
Процедура ЗаписатьРезультат(Знач Файл, Знач Маркер, Знач Текст)
	Запись = Новый ЗаписьТекста(Файл, КодировкаТекста.UTF8);
	Запись.ЗаписатьСтроку(Маркер);
	Запись.ЗаписатьСтроку(Текст);
	Запись.Закрыть();
КонецПроцедуры
