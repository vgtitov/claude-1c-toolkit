// Обработка-регистратор внешней обработки/отчёта в БСП
// «Дополнительные отчёты и обработки» (справочник ДополнительныеОтчетыИОбработки).
//
// ОБЕЗЛИЧЕННЫЙ ШАБЛОН toolkit. Кладётся в модуль объекта внешней обработки,
// собирается в .epf (build_external), запускается headless через
// apply.bsp.register_external -> 1С:Предприятие /Execute с
// /C"<путь к целевой .epf>;<Раздел>;<путь к файлу-результату>".
//
// Клиентский запуск ENTERPRISE не возвращает код ошибки, а Сообщить/ЖР не
// попадают в /Out, поэтому итог пишется в ФАЙЛ-РЕЗУЛЬТАТ (3-е поле /C):
// маркер "__ENT_OK__" при успехе, "Ошибка: ..." при сбое. Python читает файл.
//
// ВНИМАНИЕ: точку входа для /Execute и имена методов API БСП сверять с версией
// платформы/БСП организации (см. общий модуль ДополнительныеОтчетыИОбработки).

Перем ФайлРезультата;

Процедура ПередЗапуском(Отказ, ПараметрыФормы, ДополнительныеПараметры) Экспорт
    Отказ = Истина; // форму не открываем, работаем в фоне запуска
    ФайлРезультата = "";
    Попытка
        ЗарегистрироватьПоПараметруЗапуска();
        ЗаписатьРезультат("__ENT_OK__");
    Исключение
        ЗаписатьРезультат("Ошибка: " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
    КонецПопытки;
    ЗавершитьРаботуСистемы(Ложь);
КонецПроцедуры

Процедура ЗарегистрироватьПоПараметруЗапуска()
    // ПараметрЗапуска = "<путь к .epf>;<Раздел>;<путь к файлу-результату>"
    Части = СтрРазделить(ПараметрЗапуска, ";", Ложь);
    ПутьКФайлу     = ?(Части.Количество() > 0, СокрЛП(Части[0]), "");
    Раздел         = ?(Части.Количество() > 1, СокрЛП(Части[1]), "");
    ФайлРезультата = ?(Части.Количество() > 2, СокрЛП(Части[2]), "");

    Если ПустаяСтрока(ПутьКФайлу) Тогда
        ВызватьИсключение "Не задан путь к внешней обработке (ПараметрЗапуска)";
    КонецЕсли;

    ДвоичныеДанные = Новый ДвоичныеДанные(ПутьКФайлу);

    // Типовой контур БСП (имена методов сверять по версии):
    Регистрация = ДополнительныеОтчетыИОбработки.РегистрацияНовойВнешнейОбработки(ДвоичныеДанные);
    Объект = Регистрация.Объект; // СправочникОбъект.ДополнительныеОтчетыИОбработки
    Объект.Публикация = Перечисления.ВариантыПубликацииДополнительныхОтчетовИОбработок.Используется;

    Если НЕ ПустаяСтрока(Раздел) Тогда
        ДобавитьРаздел(Объект, Раздел);
    КонецЕсли;

    Объект.Записать();
КонецПроцедуры

Процедура ДобавитьРаздел(Объект, ИмяРаздела)
    Раздел = ПланыВидовХарактеристик.ИдентификаторыОбъектовМетаданных.НайтиПоНаименованию(ИмяРаздела);
    Если Раздел <> Неопределено И НЕ Раздел.Пустая() Тогда
        НоваяСтрока = Объект.Разделы.Добавить();
        НоваяСтрока.Раздел = Раздел;
    КонецЕсли;
КонецПроцедуры

Процедура ЗаписатьРезультат(Текст)
    // Дублируем в журнал регистрации и в файл-результат (файл читает toolkit).
    ЗаписьЖурналаРегистрации("onec_metadata.БСП", УровеньЖурналаРегистрации.Информация, , , Текст);
    Если НЕ ПустаяСтрока(ФайлРезультата) Тогда
        Попытка
            Запись = Новый ЗаписьТекста(ФайлРезультата, КодировкаТекста.UTF8);
            Запись.ЗаписатьСтроку(Текст);
            Запись.Закрыть();
        Исключение
            ЗаписьЖурналаРегистрации("onec_metadata.БСП",
                УровеньЖурналаРегистрации.Предупреждение, , ,
                "Не удалось записать файл-результат: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
        КонецПопытки;
    КонецЕсли;
КонецПроцедуры
