// Обработка-регистратор внешней обработки/отчёта в БСП
// «Дополнительные отчёты и обработки» (справочник ДополнительныеОтчетыИОбработки).
//
// ОБЕЗЛИЧЕННЫЙ ШАБЛОН toolkit. Кладётся в модуль объекта внешней обработки,
// собирается в .epf (build_external), запускается headless через
// apply.bsp.register_external → 1С:Предприятие /Execute с /C=<путь_epf>[;<раздел>].
//
// Клиентский запуск ENTERPRISE не возвращает код ошибки, поэтому успех
// сигналится маркером __ENT_OK__ в /Out-лог, а сбой — текстом с «Ошибк».

Процедура ПередЗапуском(Отказ, ПараметрыФормы, ДополнительныеПараметры) Экспорт
    // Не открываем форму — работаем в фоне запуска.
    Отказ = Истина;
    Попытка
        ЗарегистрироватьПоПараметруЗапуска();
        ЗаписьЖурналаРегистрации("onec_metadata.БСП", УровеньЖурналаРегистрации.Информация,
            , , "__ENT_OK__");
    Исключение
        ЗаписьЖурналаРегистрации("onec_metadata.БСП", УровеньЖурналаРегистрации.Ошибка,
            , , "Ошибка регистрации: " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
    КонецПопытки;
    ЗавершитьРаботуСистемы(Ложь);
КонецПроцедуры

Процедура ЗарегистрироватьПоПараметруЗапуска()
    Параметр = ПараметрЗапуска; // "<путь к .epf>[;<Раздел командного интерфейса>]"
    Части = СтрРазделить(Параметр, ";", Ложь);
    ПутьКФайлу = ?(Части.Количество() > 0, СокрЛП(Части[0]), "");
    Раздел = ?(Части.Количество() > 1, СокрЛП(Части[1]), "");

    Если ПустаяСтрока(ПутьКФайлу) Тогда
        ВызватьИсключение "Не задан путь к внешней обработке (ПараметрЗапуска)";
    КонецЕсли;

    ДвоичныеДанные = Новый ДвоичныеДанные(ПутьКФайлу);

    // API БСП: регистрация/обновление доп. обработки из двоичных данных.
    // Имена методов зависят от версии БСП — организация сверяет по коду типовой
    // (см. общий модуль ДополнительныеОтчетыИОбработки). Ниже — типовой контур:
    Регистрация = ДополнительныеОтчетыИОбработки.РегистрацияНовойВнешнейОбработки(ДвоичныеДанные);
    Объект = Регистрация.Объект; // СправочникОбъект.ДополнительныеОтчетыИОбработки
    Объект.Публикация = Перечисления.ВариантыПубликацииДополнительныхОтчетовИОбработок.Используется;

    Если НЕ ПустаяСтрока(Раздел) Тогда
        ДобавитьРаздел(Объект, Раздел);
    КонецЕсли;

    Объект.Записать();
КонецПроцедуры

Процедура ДобавитьРаздел(Объект, ИмяРаздела)
    // Раздел командного интерфейса, где показывать обработку.
    Раздел = ПланыВидовХарактеристик.ИдентификаторыОбъектовМетаданных.НайтиПоНаименованию(ИмяРаздела);
    Если Раздел <> Неопределено И НЕ Раздел.Пустая() Тогда
        НоваяСтрока = Объект.Разделы.Добавить();
        НоваяСтрока.Раздел = Раздел;
    КонецЕсли;
КонецПроцедуры
