// aidbg_Сервер - логика слоя данных ai_debug (read-only). Контракт HTTP и клиент:
// mcp/onec_data_mcp.py (MCP onec-data); архитектура: docs/data-access-architecture.md.
//
// Гарантии безопасности (ревью обязано их проверять при любой правке):
//  1) записи данных нет: только Запрос.Выполнить(), СКД в таблицу значений, чтение настроек
//     и вызов методов из белого списка aidbg_Настройки.РазрешенныеМетоды();
//  2) привилегированный режим включается ТОЛЬКО явно (mode=privileged) и ТОЛЬКО если
//     aidbg_Настройки.ПривилегированныйРежимРазрешен(); свойство Privileged у модулей = Ложь;
//  3) каждый вызов пишется в журнал регистрации (события "ai_debug.*"), если ВестиЖурнал().

#Область ПрограммныйИнтерфейс

// POST /query {text, params, mode, top} → {rows, fetched, shown}
Функция ОбработатьQuery(Запрос) Экспорт

	Тело = ПрочитатьТело(Запрос);
	Если Тело = Неопределено Тогда
		Возврат ОтветОшибка(400, "тело запроса не является корректным JSON-объектом");
	КонецЕсли;

	ТекстЗапроса = СтрокаИзТела(Тело, "text");
	Если ПустаяСтрока(ТекстЗапроса) Тогда
		Возврат ОтветОшибка(400, "не задан text (текст запроса 1С)");
	КонецЕсли;
	Если Не ЭтоЧитающийЗапрос(ТекстЗапроса) Тогда
		Возврат ОтветОшибка(403, "разрешены только читающие запросы (текст должен начинаться с ВЫБРАТЬ)");
	КонецЕсли;

	Режим = РежимИзТела(Тело);
	ОписаниеОшибки = ПроверитьРежим(Режим);
	Если ОписаниеОшибки <> "" Тогда
		АудитОтказ("query", ОписаниеОшибки);
		Возврат ОтветОшибка(403, ОписаниеОшибки);
	КонецЕсли;
	Аудит("query", Режим, ТекстЗапроса);

	ЗапросИБ = Новый Запрос(ТекстЗапроса);
	Попытка
		Параметры = Тело.Получить("params");
		Если ТипЗнч(Параметры) = Тип("Соответствие") Тогда
			Для Каждого КлючИЗначение Из Параметры Цикл
				ЗапросИБ.УстановитьПараметр(КлючИЗначение.Ключ, ЗначениеИзОписания(КлючИЗначение.Значение));
			КонецЦикла;
		КонецЕсли;
	Исключение
		Возврат ОтветОшибка(400, "не разобраны параметры запроса: "
			+ КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;

	Если Режим = "privileged" Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	Попытка
		Таблица = ЗапросИБ.Выполнить().Выгрузить();
	Исключение
		Если Режим = "privileged" Тогда
			УстановитьПривилегированныйРежим(Ложь);
		КонецЕсли;
		Возврат ОтветОшибка(400, "ошибка выполнения запроса: "
			+ КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	Если Режим = "privileged" Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;

	Возврат ОтветТаблица(Таблица, ЛимитИзТела(Тело));

КонецФункции

// POST /report {report, variant, params, filters, mode, top} → {rows, fetched, shown, variant}
Функция ОбработатьReport(Запрос) Экспорт

	Тело = ПрочитатьТело(Запрос);
	Если Тело = Неопределено Тогда
		Возврат ОтветОшибка(400, "тело запроса не является корректным JSON-объектом");
	КонецЕсли;

	ИмяОтчета = СтрокаИзТела(Тело, "report");
	Если ПустаяСтрока(ИмяОтчета) Тогда
		Возврат ОтветОшибка(400, "не указан отчёт (report)");
	КонецЕсли;
	МетаОтчет = Метаданные.Отчеты.Найти(ИмяОтчета);
	Если МетаОтчет = Неопределено Тогда
		Возврат ОтветОшибка(404, "отчёт '" + ИмяОтчета + "' не найден в конфигурации");
	КонецЕсли;
	Если МетаОтчет.ОсновнаяСхемаКомпоновкиДанных = Неопределено Тогда
		Возврат ОтветОшибка(400, "у отчёта '" + ИмяОтчета
			+ "' нет основной схемы компоновки данных (не СКД-отчёт)");
	КонецЕсли;

	Режим = РежимИзТела(Тело);
	ОписаниеОшибки = ПроверитьРежим(Режим);
	Если ОписаниеОшибки <> "" Тогда
		АудитОтказ("report", ОписаниеОшибки);
		Возврат ОтветОшибка(403, ОписаниеОшибки);
	КонецЕсли;
	Аудит("report", Режим, ИмяОтчета + "/" + СтрокаИзТела(Тело, "variant"));

	ОбъектОтчета = Отчеты[ИмяОтчета].Создать();
	Схема = ОбъектОтчета.ПолучитьМакет(МетаОтчет.ОсновнаяСхемаКомпоновкиДанных);

	ИмяВарианта = СтрокаИзТела(Тело, "variant");
	Если ПустаяСтрока(ИмяВарианта) Тогда
		НастройкиСКД = Схема.НастройкиПоУмолчанию;
	Иначе
		ВариантНастроек = Схема.ВариантыНастроек.Найти(ИмяВарианта);
		Если ВариантНастроек = Неопределено Тогда
			Доступные = Новый Массив;
			Для Каждого Вариант Из Схема.ВариантыНастроек Цикл
				Доступные.Добавить(Вариант.Имя);
			КонецЦикла;
			Ответ = Новый Структура("error, variants",
				"вариант '" + ИмяВарианта + "' не найден", Доступные);
			Возврат ОтветJSON(404, Ответ);
		КонецЕсли;
		НастройкиСКД = ВариантНастроек.Настройки;
	КонецЕсли;

	Компоновщик = Новый КомпоновщикНастроекКомпоновкиДанных;
	Компоновщик.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(Схема));
	Компоновщик.ЗагрузитьНастройки(НастройкиСКД);

	// разбор параметров/отборов - предмет ОШИБКИ КЛИЕНТА (кривой вид сравнения, тип);
	// оборачиваем в Попытку и отдаём 400 с подсказкой, а не 500
	КоличествоОтборов = 0;
	Попытка
		Параметры = Тело.Получить("params");
		Если ТипЗнч(Параметры) = Тип("Соответствие") Тогда
			Для Каждого КлючИЗначение Из Параметры Цикл
				Компоновщик.Настройки.ПараметрыДанных.УстановитьЗначениеПараметра(
					КлючИЗначение.Ключ, ЗначениеИзОписания(КлючИЗначение.Значение));
			КонецЦикла;
		КонецЕсли;

		Отборы = Тело.Получить("filters");
		Если ТипЗнч(Отборы) = Тип("Массив") Тогда
			Для Каждого ОписаниеОтбора Из Отборы Цикл
				Если ТипЗнч(ОписаниеОтбора) <> Тип("Соответствие") Тогда
					Продолжить;
				КонецЕсли;
				Элемент = Компоновщик.Настройки.Отбор.Элементы.Добавить(
					Тип("ЭлементОтбораКомпоновкиДанных"));
				Элемент.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(
					Строка(ОписаниеОтбора.Получить("field")));
				ВидСравненияСтрокой = Строка(ОписаниеОтбора.Получить("kind"));
				Если ПустаяСтрока(ВидСравненияСтрокой) Тогда
					ВидСравненияСтрокой = "Равно";
				КонецЕсли;
				Элемент.ВидСравнения = ВидСравненияПоИмени(ВидСравненияСтрокой);
				Элемент.ПравоеЗначение = ЗначениеИзОписания(ОписаниеОтбора.Получить("value"));
				Элемент.Использование = Истина;
				КоличествоОтборов = КоличествоОтборов + 1;
			КонецЦикла;
		КонецЕсли;
	Исключение
		Возврат ОтветОшибка(400, "не разобраны параметры/отборы отчёта: "
			+ КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;

	Если Режим = "privileged" Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	Попытка
		КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
		МакетКомпоновки = КомпоновщикМакета.Выполнить(Схема, Компоновщик.ПолучитьНастройки(),
			, , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
		Процессор = Новый ПроцессорКомпоновкиДанных;
		// 4-й параметр = МожноИспользоватьВнешниеФункции: для read-only отладки НЕ нужен
		// (иначе выражения схемы смогут звать экспортные функции - расширение поверхности)
		Процессор.Инициализировать(МакетКомпоновки, , , Ложь);
		Таблица = Новый ТаблицаЗначений;
		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
		ПроцессорВывода.УстановитьОбъект(Таблица);
		ПроцессорВывода.Вывести(Процессор);
	Исключение
		Если Режим = "privileged" Тогда
			УстановитьПривилегированныйРежим(Ложь);
		КонецЕсли;
		Возврат ОтветОшибка(400, "ошибка формирования отчёта: "
			+ КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	Если Режим = "privileged" Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;

	Ответ = ТаблицаВСтруктуру(Таблица, ЛимитИзТела(Тело));
	Ответ.Вставить("variant", ИмяВарианта);
	Ответ.Вставить("filters_applied", КоличествоОтборов);
	Возврат ОтветJSON(200, Ответ);

КонецФункции

// POST /settings {what, names, params, target_user, mode} → значения настроек
Функция ОбработатьSettings(Запрос) Экспорт

	Тело = ПрочитатьТело(Запрос);
	Если Тело = Неопределено Тогда
		Возврат ОтветОшибка(400, "тело запроса не является корректным JSON-объектом");
	КонецЕсли;

	Что = СтрокаИзТела(Тело, "what");
	Режим = РежимИзТела(Тело);
	ОписаниеОшибки = ПроверитьРежим(Режим);
	Если ОписаниеОшибки <> "" Тогда
		АудитОтказ("settings", ОписаниеОшибки);
		Возврат ОтветОшибка(403, ОписаниеОшибки);
	КонецЕсли;
	Аудит("settings", Режим, Что);

	Имена = Тело.Получить("names");
	Если ТипЗнч(Имена) <> Тип("Массив") Тогда
		Имена = Новый Массив;
	КонецЕсли;

	Если Режим = "privileged" Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	Попытка
		Ответ = НастройкиПоВиду(Что, Имена, Тело);
	Исключение
		Если Режим = "privileged" Тогда
			УстановитьПривилегированныйРежим(Ложь);
		КонецЕсли;
		Возврат ОтветОшибка(400, "ошибка чтения настроек: "
			+ КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	Если Режим = "privileged" Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;

	Если Ответ = Неопределено Тогда
		Возврат ОтветОшибка(400, "неизвестный what '" + Что
			+ "' (constants | functional_options | user_settings | access)");
	КонецЕсли;
	Возврат ОтветJSON(200, Ответ);

КонецФункции

// POST /call {method, args, mode} → {result}. Только методы из белого списка.
Функция ОбработатьCall(Запрос) Экспорт

	Тело = ПрочитатьТело(Запрос);
	Если Тело = Неопределено Тогда
		Возврат ОтветОшибка(400, "тело запроса не является корректным JSON-объектом");
	КонецЕсли;

	ИмяМетода = СтрокаИзТела(Тело, "method");
	Разрешенные = aidbg_Настройки.РазрешенныеМетоды();
	Если Разрешенные.Найти(ИмяМетода) = Неопределено Тогда
		АудитОтказ("call", "метод вне whitelist: " + ИмяМетода);
		Возврат ОтветОшибка(403, "метод '" + ИмяМетода
			+ "' не в whitelist (aidbg_Настройки.РазрешенныеМетоды)");
	КонецЕсли;
	Если Не ИмяМетодаКорректно(ИмяМетода) Тогда
		Возврат ОтветОшибка(400, "имя метода должно иметь вид ОбщийМодуль.Функция");
	КонецЕсли;

	Режим = РежимИзТела(Тело);
	ОписаниеОшибки = ПроверитьРежим(Режим);
	Если ОписаниеОшибки <> "" Тогда
		АудитОтказ("call", ОписаниеОшибки);
		Возврат ОтветОшибка(403, ОписаниеОшибки);
	КонецЕсли;
	Аудит("call", Режим, ИмяМетода);

	АргументыОписания = Тело.Получить("args");
	ПараметрыВызова = Новый Массив;
	Если ТипЗнч(АргументыОписания) = Тип("Массив") Тогда
		Для Каждого Описание Из АргументыОписания Цикл
			ПараметрыВызова.Добавить(ЗначениеИзОписания(Описание));
		КонецЦикла;
	КонецЕсли;

	СтрокаВызова = ИмяМетода + "(";
	Для Индекс = 0 По ПараметрыВызова.ВГраница() Цикл
		Если Индекс > 0 Тогда
			СтрокаВызова = СтрокаВызова + ", ";
		КонецЕсли;
		СтрокаВызова = СтрокаВызова + "ПараметрыВызова[" + Формат(Индекс, "ЧГ=0") + "]";
	КонецЦикла;
	СтрокаВызова = СтрокаВызова + ")";

	Если Режим = "privileged" Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	Попытка
		Результат = Вычислить(СтрокаВызова);
	Исключение
		Если Режим = "privileged" Тогда
			УстановитьПривилегированныйРежим(Ложь);
		КонецЕсли;
		Возврат ОтветОшибка(400, "ошибка вызова метода: "
			+ КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	Если Режим = "privileged" Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;

	Ответ = Новый Структура;
	Ответ.Вставить("method", ИмяМетода);
	Ответ.Вставить("result", СериализоватьЗначение(Результат));
	Возврат ОтветJSON(200, Ответ);

КонецФункции

// GET /health → под кем сеанс, версия, что разрешено на этой базе
Функция ОбработатьHealth(Запрос) Экспорт

	Ответ = Новый Структура;
	Ответ.Вставить("version", "0.1.0");
	Ответ.Вставить("session_user", ИмяПользователя());
	Ответ.Вставить("privileged_allowed", aidbg_Настройки.ПривилегированныйРежимРазрешен());
	Ответ.Вставить("methods_whitelist", aidbg_Настройки.РазрешенныеМетоды());
	Ответ.Вставить("max_rows", aidbg_Настройки.МаксимумСтрок());
	Возврат ОтветJSON(200, Ответ);

КонецФункции

// 500 для необработанных исключений (вызывается из модуля HTTP-сервиса)
Функция ОтветВнутренняяОшибка(ИнформацияОшибки) Экспорт

	Возврат ОтветОшибка(500, "внутренняя ошибка ai_debug: "
		+ КраткоеПредставлениеОшибки(ИнформацияОшибки));

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПрочитатьТело(Запрос)

	// Тело читаем ДВОИЧНО и раскодируем UTF-8 ЯВНО: ПолучитьТелоКакСтроку() кодировку
	// параметром не принимает, то есть полагается на умолчание платформы, а контракт
	// сервиса — UTF-8. Так поведение не зависит от догадок о charset.
	// NB: наблюдавшаяся в отладке битая кириллица в теле оказалась дефектом СТЕНДА, а не
	// платформы — тело с кириллицей терялось при передаче через командную строку Windows.
	// Проверять такие запросы только телом из файла в UTF-8.
	Попытка
		ТелоСтрокой = ПолучитьСтрокуИзДвоичныхДанных(
			Запрос.ПолучитьТелоКакДвоичныеДанные(), КодировкаТекста.UTF8);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	// защита от гигантского POST (память сервера): 1 МБ на запрос с запасом
	Если СтрДлина(ТелоСтрокой) > 1048576 Тогда
		Возврат Неопределено;
	КонецЕсли;
	Попытка
		Чтение = Новый ЧтениеJSON;
		Чтение.УстановитьСтроку(ТелоСтрокой);
		Данные = ПрочитатьJSON(Чтение, Истина);
		Чтение.Закрыть();
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	Если ТипЗнч(Данные) <> Тип("Соответствие") Тогда
		Возврат Неопределено;
	КонецЕсли;
	Возврат Данные;

КонецФункции

Функция СтрокаИзТела(Тело, Ключ)

	Значение = Тело.Получить(Ключ);
	Если Значение = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Возврат Строка(Значение);

КонецФункции

Функция РежимИзТела(Тело)

	Режим = СтрокаИзТела(Тело, "mode");
	Если ПустаяСтрока(Режим) Тогда
		Режим = "user";
	КонецЕсли;
	Возврат Режим;

КонецФункции

Функция ЛимитИзТела(Тело)

	Лимит = Тело.Получить("top");
	Если ТипЗнч(Лимит) <> Тип("Число") Тогда
		Возврат 0;
	КонецЕсли;
	Возврат Лимит;

КонецФункции

// "" = режим допустим; иначе - текст отказа. Единственная точка принятия решения о режиме.
Функция ПроверитьРежим(Режим)

	Если Режим = "user" Тогда
		Возврат "";
	ИначеЕсли Режим = "privileged" Тогда
		Если aidbg_Настройки.ПривилегированныйРежимРазрешен() Тогда
			Возврат "";
		КонецЕсли;
		Возврат "привилегированный режим запрещён настройками ai_debug на этой базе";
	КонецЕсли;
	Возврат "неизвестный режим '" + Режим + "' (user | privileged)";

КонецФункции

Функция ЭтоЧитающийЗапрос(ТекстЗапроса)

	// срезать ведущие строчные комментарии (агент часто предваряет запрос `// ...`)
	Строки = СтрРазделить(ТекстЗапроса, Символы.ПС, Ложь);
	Очищенный = "";
	Для Каждого Строка Из Строки Цикл
		СтрокаБезПробелов = СокрЛП(Строка);
		Если ПустаяСтрока(Очищенный) И (ПустаяСтрока(СтрокаБезПробелов)
			ИЛИ СтрНачинаетсяС(СтрокаБезПробелов, "//")) Тогда
			Продолжить; // пропускаем ведущие пустые строки и комментарии
		КонецЕсли;
		Очищенный = Очищенный + ?(ПустаяСтрока(Очищенный), "", Символы.ПС) + Строка;
	КонецЦикла;

	Нормализованный = ВРег(СокрЛП(Очищенный));
	Возврат СтрНачинаетсяС(Нормализованный, "ВЫБРАТЬ")
		ИЛИ СтрНачинаетсяС(Нормализованный, "SELECT");

КонецФункции

// Вид сравнения СКД по строковому имени с внятной ошибкой (кривой kind → 400, не 500).
Функция ВидСравненияПоИмени(Имя)

	Попытка
		Возврат ВидСравненияКомпоновкиДанных[Имя];
	Исключение
		ВызватьИсключение "неизвестный вид сравнения '" + Имя
			+ "' (примеры: Равно, НеРавно, Больше, Меньше, ВСписке, Содержит, НачинаетсяС)";
	КонецПопытки;

КонецФункции

Функция ИмяМетодаКорректно(ИмяМетода)

	Части = СтрРазделить(ИмяМетода, ".");
	Если Части.Количество() <> 2 Тогда
		Возврат Ложь;
	КонецЕсли;
	Для Каждого Часть Из Части Цикл
		Если ПустаяСтрока(Часть) Тогда
			Возврат Ложь;
		КонецЕсли;
		Для НомерСимвола = 1 По СтрДлина(Часть) Цикл
			Символ = Сред(Часть, НомерСимвола, 1);
			КодСимвола = КодСимвола(Символ);
			ЭтоБуква = (КодСимвола >= КодСимвола("А") И КодСимвола <= КодСимвола("я"))
				ИЛИ (ВРег(Символ) >= "A" И ВРег(Символ) <= "Z")
				ИЛИ Символ = "_" ИЛИ Символ = "Ё" ИЛИ Символ = "ё";
			ЭтоЦифра = Символ >= "0" И Символ <= "9";
			Если Не ЭтоБуква И Не (ЭтоЦифра И НомерСимвола > 1) Тогда
				Возврат Ложь;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	Возврат Истина;

КонецФункции

Функция НастройкиПоВиду(Что, Имена, Тело)

	Если Что = "constants" Тогда
		Значения = Новый Структура;
		Для Каждого Имя Из Имена Цикл
			МетаКонстанта = Метаданные.Константы.Найти(Имя);
			Если МетаКонстанта = Неопределено Тогда
				Значения.Вставить(Имя, "<константа не найдена>");
			Иначе
				Значения.Вставить(Имя, СериализоватьЗначение(Константы[Имя].Получить()));
			КонецЕсли;
		КонецЦикла;
		Возврат Новый Структура("constants", Значения);

	ИначеЕсли Что = "functional_options" Тогда
		ПараметрыФО = Новый Структура;
		ОписанияПараметров = Тело.Получить("params");
		Если ТипЗнч(ОписанияПараметров) = Тип("Соответствие") Тогда
			Для Каждого КлючИЗначение Из ОписанияПараметров Цикл
				ПараметрыФО.Вставить(КлючИЗначение.Ключ, ЗначениеИзОписания(КлючИЗначение.Значение));
			КонецЦикла;
		КонецЕсли;
		Значения = Новый Структура;
		Для Каждого Имя Из Имена Цикл
			Если Метаданные.ФункциональныеОпции.Найти(Имя) = Неопределено Тогда
				Значения.Вставить(Имя, "<функциональная опция не найдена>");
			ИначеЕсли ПараметрыФО.Количество() = 0 Тогда
				Значения.Вставить(Имя, ПолучитьФункциональнуюОпцию(Имя));
			Иначе
				Значения.Вставить(Имя, ПолучитьФункциональнуюОпцию(Имя, ПараметрыФО));
			КонецЕсли;
		КонецЦикла;
		Возврат Новый Структура("functional_options", Значения);

	ИначеЕсли Что = "user_settings" Тогда
		Если Имена.Количество() < 2 Тогда
			Возврат Новый Структура("error",
				"для user_settings нужны names = [КлючОбъекта, КлючНастроек]");
		КонецЕсли;
		ЦелевойПользователь = СтрокаИзТела(Тело, "target_user");
		Если ПустаяСтрока(ЦелевойПользователь) Тогда
			Настройка = ХранилищеОбщихНастроек.Загрузить(Имена[0], Имена[1]);
		Иначе
			Настройка = ХранилищеОбщихНастроек.Загрузить(Имена[0], Имена[1], , ЦелевойПользователь);
		КонецЕсли;
		Возврат Новый Структура("user_settings", СериализоватьЗначение(Настройка));

	ИначеЕсли Что = "access" Тогда
		Возврат ОписаниеДоступаПользователя(СтрокаИзТела(Тело, "target_user"));
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

Функция ОписаниеДоступаПользователя(ИмяЦелевогоПользователя)

	Если ПустаяСтрока(ИмяЦелевогоПользователя) Тогда
		ПользовательИБ = ПользователиИнформационнойБазы.ТекущийПользователь();
	Иначе
		ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоИмени(ИмяЦелевогоПользователя);
		Если ПользовательИБ = Неопределено Тогда
			Возврат Новый Структура("error",
				"пользователь ИБ '" + ИмяЦелевогоПользователя + "' не найден");
		КонецЕсли;
	КонецЕсли;

	Роли = Новый Массив;
	Для Каждого Роль Из ПользовательИБ.Роли Цикл
		Роли.Добавить(Роль.Имя);
	КонецЦикла;

	// группы доступа БСП - опционально (в конфигурациях без БСП вернётся предупреждение)
	ГруппыДоступа = Новый Массив;
	ПредупреждениеБСП = "";
	Попытка
		ЗапросГрупп = Новый Запрос(
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ГруппыДоступаПользователи.Ссылка.Наименование КАК Наименование
			|ИЗ
			|	Справочник.ГруппыДоступа.Пользователи КАК ГруппыДоступаПользователи
			|ГДЕ
			|	ГруппыДоступаПользователи.Пользователь.ИдентификаторПользователяИБ = &Идентификатор");
		ЗапросГрупп.УстановитьПараметр("Идентификатор", ПользовательИБ.УникальныйИдентификатор);
		Выборка = ЗапросГрупп.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			ГруппыДоступа.Добавить(Строка(Выборка.Наименование));
		КонецЦикла;
	Исключение
		ПредупреждениеБСП = "группы доступа не прочитаны (нет БСП или нет прав): "
			+ КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;

	Ответ = Новый Структура;
	Ответ.Вставить("target_user", ПользовательИБ.Имя);
	Ответ.Вставить("roles", Роли);
	Ответ.Вставить("access_groups", ГруппыДоступа);
	Если ПредупреждениеБСП <> "" Тогда
		Ответ.Вставить("warning", ПредупреждениеБСП);
	КонецЕсли;
	Возврат Ответ;

КонецФункции

// Описание значения из JSON → значение 1С: примитивы как есть; {"date": ISO} → Дата;
// {"ref": "Справочник.Имя", "uuid": "…"} → ссылка; {"enum": "Перечисление.Имя",
// "value": "ИмяЗначения"} → значение перечисления; массив → массив (для ВСписке).
Функция ЗначениеИзОписания(Описание)

	Если ТипЗнч(Описание) = Тип("Массив") Тогда
		Результат = Новый Массив;
		Для Каждого Элемент Из Описание Цикл
			Результат.Добавить(ЗначениеИзОписания(Элемент));
		КонецЦикла;
		Возврат Результат;
	КонецЕсли;
	Если ТипЗнч(Описание) <> Тип("Соответствие") Тогда
		Возврат Описание;
	КонецЕсли;

	Если Описание.Получить("date") <> Неопределено Тогда
		Возврат ПрочитатьДатуJSON(Строка(Описание.Получить("date")), ФорматДатыJSON.ISO);
	КонецЕсли;

	ПолноеИмяСсылки = Описание.Получить("ref");
	Если ПолноеИмяСсылки <> Неопределено Тогда
		Возврат СсылкаПоОписанию(Строка(ПолноеИмяСсылки), Строка(Описание.Получить("uuid")));
	КонецЕсли;

	ПолноеИмяПеречисления = Описание.Получить("enum");
	Если ПолноеИмяПеречисления <> Неопределено Тогда
		Части = СтрРазделить(Строка(ПолноеИмяПеречисления), ".");
		Возврат Перечисления[Части[Части.ВГраница()]][Строка(Описание.Получить("value"))];
	КонецЕсли;

	Возврат Описание;

КонецФункции

Функция СсылкаПоОписанию(ПолноеИмя, ИдентификаторСтрокой)

	Части = СтрРазделить(ПолноеИмя, ".");
	Если Части.Количество() <> 2 Тогда
		ВызватьИсключение "ref должен иметь вид 'Справочник.Имя', получено: " + ПолноеИмя;
	КонецЕсли;
	Вид = Части[0];
	Имя = Части[1];
	Идентификатор = Новый УникальныйИдентификатор(ИдентификаторСтрокой);
	Если Вид = "Справочник" Тогда
		Возврат Справочники[Имя].ПолучитьСсылку(Идентификатор);
	ИначеЕсли Вид = "Документ" Тогда
		Возврат Документы[Имя].ПолучитьСсылку(Идентификатор);
	ИначеЕсли Вид = "ПланВидовХарактеристик" Тогда
		Возврат ПланыВидовХарактеристик[Имя].ПолучитьСсылку(Идентификатор);
	ИначеЕсли Вид = "ПланСчетов" Тогда
		Возврат ПланыСчетов[Имя].ПолучитьСсылку(Идентификатор);
	ИначеЕсли Вид = "ПланВидовРасчета" Тогда
		Возврат ПланыВидовРасчета[Имя].ПолучитьСсылку(Идентификатор);
	ИначеЕсли Вид = "БизнесПроцесс" Тогда
		Возврат БизнесПроцессы[Имя].ПолучитьСсылку(Идентификатор);
	ИначеЕсли Вид = "Задача" Тогда
		Возврат Задачи[Имя].ПолучитьСсылку(Идентификатор);
	ИначеЕсли Вид = "ПланОбмена" Тогда
		Возврат ПланыОбмена[Имя].ПолучитьСсылку(Идентификатор);
	КонецЕсли;
	ВызватьИсключение "неподдерживаемый вид ссылки: " + Вид;

КонецФункции

// Значение 1С → JSON-совместимое: примитивы; Дата → ISO; ссылка → {_ref, uuid|value,
// presentation}; прочее → строковое представление.
Функция СериализоватьЗначение(Значение)

	ТипЗначения = ТипЗнч(Значение);
	Если Значение = Неопределено ИЛИ Значение = NULL Тогда
		Возврат Неопределено;
	ИначеЕсли ТипЗначения = Тип("Строка") ИЛИ ТипЗначения = Тип("Число")
		ИЛИ ТипЗначения = Тип("Булево") Тогда
		Возврат Значение;
	ИначеЕсли ТипЗначения = Тип("Дата") Тогда
		Возврат Формат(Значение, "ДФ=yyyy-MM-ddTHH:mm:ss");
	ИначеЕсли ТипЗначения = Тип("УникальныйИдентификатор") Тогда
		Возврат Строка(Значение);
	ИначеЕсли ЭтоСсылка(ТипЗначения) Тогда
		Возврат СериализоватьСсылку(Значение);
	ИначеЕсли ТипЗначения = Тип("Массив") Тогда
		Результат = Новый Массив;
		Для Каждого Элемент Из Значение Цикл
			Результат.Добавить(СериализоватьЗначение(Элемент));
		КонецЦикла;
		Возврат Результат;
	ИначеЕсли ТипЗначения = Тип("Структура") ИЛИ ТипЗначения = Тип("Соответствие") Тогда
		Результат = Новый Соответствие;
		Для Каждого КлючИЗначение Из Значение Цикл
			Результат.Вставить(Строка(КлючИЗначение.Ключ), СериализоватьЗначение(КлючИЗначение.Значение));
		КонецЦикла;
		Возврат Результат;
	КонецЕсли;
	Возврат Строка(Значение);

КонецФункции

Функция ЭтоСсылка(ТипЗначения)

	Возврат Справочники.ТипВсеСсылки().СодержитТип(ТипЗначения)
		ИЛИ Документы.ТипВсеСсылки().СодержитТип(ТипЗначения)
		ИЛИ Перечисления.ТипВсеСсылки().СодержитТип(ТипЗначения)
		ИЛИ ПланыВидовХарактеристик.ТипВсеСсылки().СодержитТип(ТипЗначения)
		ИЛИ ПланыСчетов.ТипВсеСсылки().СодержитТип(ТипЗначения)
		ИЛИ ПланыВидовРасчета.ТипВсеСсылки().СодержитТип(ТипЗначения)
		ИЛИ БизнесПроцессы.ТипВсеСсылки().СодержитТип(ТипЗначения)
		ИЛИ Задачи.ТипВсеСсылки().СодержитТип(ТипЗначения)
		ИЛИ ПланыОбмена.ТипВсеСсылки().СодержитТип(ТипЗначения);

КонецФункции

Функция СериализоватьСсылку(Значение)

	Результат = Новый Структура;
	Результат.Вставить("_ref", Значение.Метаданные().ПолноеИмя());
	Если Перечисления.ТипВсеСсылки().СодержитТип(ТипЗнч(Значение)) Тогда
		Результат.Вставить("value", XMLСтрока(Значение));
	Иначе
		Результат.Вставить("uuid", Строка(Значение.УникальныйИдентификатор()));
	КонецЕсли;
	Результат.Вставить("presentation", Строка(Значение));
	Возврат Результат;

КонецФункции

Функция ТаблицаВСтруктуру(Таблица, ЛимитКлиента)

	Лимит = aidbg_Настройки.МаксимумСтрок();
	Если ЛимитКлиента > 0 И ЛимитКлиента < Лимит Тогда
		Лимит = ЛимитКлиента;
	КонецЕсли;
	Всего = Таблица.Количество();
	Показать = Мин(Всего, Лимит);

	Строки = Новый Массив;
	Для Индекс = 0 По Показать - 1 Цикл
		СтрокаТаблицы = Таблица[Индекс];
		// Соответствие, а не Структура: имена колонок СКД (вложенные/итоговые поля) могут
		// быть невалидным ключом Структуры → иначе исключение уже ПОСЛЕ снятия privileged
		Элемент = Новый Соответствие;
		Для Каждого Колонка Из Таблица.Колонки Цикл
			Элемент.Вставить(Колонка.Имя, СериализоватьЗначение(СтрокаТаблицы[Колонка.Имя]));
		КонецЦикла;
		Строки.Добавить(Элемент);
	КонецЦикла;

	Ответ = Новый Структура;
	Ответ.Вставить("rows", Строки);
	Ответ.Вставить("fetched", Всего);
	Ответ.Вставить("shown", Показать);
	Возврат Ответ;

КонецФункции

Функция ОтветТаблица(Таблица, ЛимитКлиента)

	Возврат ОтветJSON(200, ТаблицаВСтруктуру(Таблица, ЛимитКлиента));

КонецФункции

Функция ОтветОшибка(КодСостояния, Описание)

	Возврат ОтветJSON(КодСостояния, Новый Структура("error", Описание));

КонецФункции

Функция ОтветJSON(КодСостояния, Данные)

	Ответ = Новый HTTPСервисОтвет(КодСостояния);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Запись = Новый ЗаписьJSON;
	Запись.УстановитьСтроку(Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет));
	ЗаписатьJSON(Запись, Данные);
	Ответ.УстановитьТелоИзСтроки(Запись.Закрыть());
	Возврат Ответ;

КонецФункции

Процедура Аудит(Операция, Режим, Детали)

	Если Не aidbg_Настройки.ВестиЖурнал() Тогда
		Возврат;
	КонецЕсли;
	ЗаписьЖурналаРегистрации("ai_debug." + Операция,
		УровеньЖурналаРегистрации.Информация, , ,
		"mode=" + Режим + "; user=" + ИмяПользователя() + "; " + Лев(Детали, 500));

КонецПроцедуры

// Отклонённые попытки (privileged на проде, метод вне whitelist) - самые интересные для
// security-мониторинга события; пишем отдельным событием уровня Предупреждение.
Процедура АудитОтказ(Операция, Причина)

	Если Не aidbg_Настройки.ВестиЖурнал() Тогда
		Возврат;
	КонецЕсли;
	ЗаписьЖурналаРегистрации("ai_debug.denied",
		УровеньЖурналаРегистрации.Предупреждение, , ,
		"op=" + Операция + "; user=" + ИмяПользователя() + "; " + Лев(Причина, 500));

КонецПроцедуры

#КонецОбласти
