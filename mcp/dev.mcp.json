{
  "//": "LEGACY-алиас для совместимости. КАНОН профиля MCP — core/mcp/servers.json (из него build.sh генерирует .mcp.json). Держи синхронным или ссылайся на core/mcp/servers.json.",

  "mcpServers": {
    "onec-code": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--quiet",
        "${ONEC_SRC_DIR}/onec_mcp.py"
      ],
      "env": {
        "ONEC_SRC_DIR": "${ONEC_SRC_DIR}"
      }
    },
    "bsl-platform": {
      "type": "stdio",
      "command": "java",
      "args": [
        "-Dfile.encoding=UTF-8",
        "-jar",
        "${BSL_PLATFORM_JAR}",
        "--platform-path",
        "${ONEC_PLATFORM_PATH}"
      ],
      "env": {}
    },
    "bsl-ls": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--quiet",
        "${BSL_LS_MCP}"
      ],
      "env": {
        "BSL_JAR": "${BSL_JAR}",
        "BSL_MEMORY_MB": "${BSL_MEMORY_MB:-4096}"
      }
    },
    "onec-ops": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--quiet",
        "${ONEC_OPS_MCP}"
      ],
      "env": {
        "ZABBIX_URL": "${ZABBIX_URL:-}",
        "ZABBIX_TOKEN": "${ZABBIX_TOKEN:-}",
        "PROMETHEUS_URL": "${PROMETHEUS_URL:-}"
      }
    },
    "onec-data": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--quiet",
        "${ONEC_DATA_MCP}"
      ],
      "env": {
        "ONEC_DATA_BASE_URL": "${ONEC_DATA_BASE_URL:-}",
        "ONEC_DATA_USERS": "${ONEC_DATA_USERS:-}",
        "ONEC_DATA_DEFAULT_USER": "${ONEC_DATA_DEFAULT_USER:-}",
        "ONEC_DATA_ODATA_PATH": "${ONEC_DATA_ODATA_PATH:-/odata/standard.odata}",
        "ONEC_DATA_DEBUG_PATH": "${ONEC_DATA_DEBUG_PATH:-/hs/aidbg}",
        "ONEC_DATA_MAX_ROWS": "${ONEC_DATA_MAX_ROWS:-200}",
        "ONEC_DATA_FORBID_PRIVILEGED": "${ONEC_DATA_FORBID_PRIVILEGED:-}",
        "ONEC_DATA_MASK_FIELDS": "${ONEC_DATA_MASK_FIELDS:-}",
        "ONEC_DATA_MASK_OFF": "${ONEC_DATA_MASK_OFF:-}",
        "ONEC_DATA_PRESETS": "${ONEC_DATA_PRESETS:-}"
      }
    }
  }
}