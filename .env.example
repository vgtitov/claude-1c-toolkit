# Шаблон .env — скопируйте в .env рядом и заполните под свой контур. Сам .env в git не попадает.
# Секреты — ТОЛЬКО здесь (в .env) или в переменных окружения; никогда в чат, коммиты, задачи.
# CLI (zabbix_perf.py, storage_map.py, atlassian.py, apdex_to_zabbix.py) подхватывают .env
# из текущего каталога, затем из корня репозитория; переменные окружения главнее файла.

# --- onec-code / onec-ops: чтение исходников 1С ---
ONEC_SRC_DIR=                 # каталог с выгруженными исходниками (EDT/конфигуратор)
ONEC_LAYERS_CONFIG=           # конфиг слоёв (см. config/layers.example.toml)

# --- Zabbix (zabbix_perf.py, onec-ops zabbix_*_tool): анализ производительности ---
# Токен: Zabbix UI → Профиль пользователя → API tokens (учётка read-only,
# в роли включены «Доступ к API» и «Управление API-токенами»).
ZABBIX_URL=                   # http://zabbix.example/api_jsonrpc.php (можно URL фронтенда)
ZABBIX_TOKEN=

# --- Карты структуры хранения (storage_map.py): таблица СУБД ↔ объект 1С ---
# Каталог карт по базам (index.json + <База>.csv). Импорт выгрузки:
#   python scripts/storage_map.py import <файл.xls|csv> --base <ИмяБазы>
# Если задан — perf-отчёт Zabbix сам расшифровывает таблицы в SQL-уликах.
# Без переменной берётся <репозиторий>/data/storage_maps, если существует
# (локализации могут зашивать карты прямо в свой репозиторий).
ONEC_STORAGE_MAPS_DIR=

# --- Prometheus (опционально, если метрики 1С отдаёт экспортер) ---
PROMETHEUS_URL=

# --- Jira / Confluence (atlassian.py) ---
# Server/DC: только *_PAT (Bearer): профиль → Personal Access Tokens (отдельно Jira и Confluence).
# Cloud: дополнительно *_USER (email) → Basic user:token.
JIRA_URL=
JIRA_PAT=
# JIRA_USER=
CONFLUENCE_URL=
CONFLUENCE_PAT=
# CONFLUENCE_USER=
