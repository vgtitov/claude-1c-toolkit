# Шаблон .env — скопируйте в .env рядом и заполните под свой контур. Сам .env в git не попадает.
# Секреты — ТОЛЬКО здесь (в .env) или в переменных окружения; никогда в чат, коммиты, задачи.
# CLI (zabbix_perf.py, storage_map.py, atlassian.py, apdex_to_zabbix.py) подхватывают .env
# из текущего каталога, затем из корня репозитория; переменные окружения главнее файла.

# --- onec-code / onec-ops: чтение исходников 1С ---
ONEC_SRC_DIR=                 # каталог с выгруженными исходниками (EDT/конфигуратор)
ONEC_LAYERS_CONFIG=           # конфиг слоёв (см. config/layers.example.toml)

# --- onec-metadata (bin/1c-meta, apply-слой): программные правки метаданных ---
# Нужны ТОЛЬКО для apply в тест-базу (сам разбор/правка XML работают без них).
# Транспорт: по SSH к серверу 1С (нужны ssh, scp, tar — Windows 10+ имеет их из коробки)
# ИЛИ локально, если платформа стоит на этой машине (тогда ssh не нужен вовсе).
ONEC_1CV8_BIN=                # путь к 1cv8(.exe); иначе авто-поиск установленной платформы
ONEC_REMOTE_WORKDIR=          # рабочий каталог НА СЕРВЕРЕ для tar/логов; по умолчанию D:\src
                              # (локально рабочий каталог берётся временный, эта переменная не нужна)

# --- Учётка ИБ (designer_sync.py, scripts/onec_verify.py: ступени 1-2 тестирования) ---
# Логин един, пароль — по базе/контуру; КЛЮЧ = имя базы в ВЕРХНЕМ регистре (--contour).
ONEC_IB_USER=
ONEC_IB_PASS=                 # фолбэк, если нет пароля с суффиксом
# ONEC_IB_PASS_<КЛЮЧ>=        # напр. ONEC_IB_PASS_ERP_TEST

# --- onec-data (слой ДАННЫХ живой ИБ: OData L1-L2 + расширение ai_debug L3) ---
# Работает ТОЛЬКО с опубликованной на веб-сервере базой (публикация — действие админа,
# см. docs/onec-work-mechanisms.md). Без публикации слой данных не включается.
ONEC_DATA_MCP=                # путь к mcp/onec_data_mcp.py (для mcp/dev.mcp.json)
ONEC_DATA_BASE_URL=           # http://веб-сервер/ИмяПубликации (регистр имени — точно как в публикации)
ONEC_DATA_USERS=              # файл учёток исследуемых пользователей (см. config/users.example.json)
ONEC_DATA_DEFAULT_USER=       # alias учётки по умолчанию
ONEC_DATA_ODATA_PATH=         # по умолчанию /odata/standard.odata
ONEC_DATA_DEBUG_PATH=         # по умолчанию /hs/aidbg
ONEC_DATA_MAX_ROWS=           # потолок строк в ответе; по умолчанию 200
ONEC_DATA_FORBID_PRIVILEGED=  # 1 — запретить mode=privileged на клиенте (прод-профиль)
ONEC_DATA_MASK_FIELDS=        # доп. поля-маски ПДн через запятую
ONEC_DATA_MASK_OFF=           # 1 — снять маскирование (ТОЛЬКО тест-база)
ONEC_DATA_PRESETS=            # файл преднастроенных проверок (см. config/presets.example.json)
# SSH-хост сервера 1С — не env, а алиас в ~/.ssh/config (передаётся в Runner(host)).
# Настройки конкретной организации (хост, базы, версия платформы) — в её ПРИВАТНОМ репо настроек.

# --- Zabbix (zabbix_perf.py, onec-ops zabbix_*_tool): анализ производительности ---
# Токен: Zabbix UI → Профиль пользователя → API tokens (учётка read-only,
# в роли включены «Доступ к API» и «Управление API-токенами»).
ZABBIX_URL=                   # http://zabbix.example/api_jsonrpc.php (можно URL фронтенда)
ZABBIX_TOKEN=
# Пресеты контуров («--contour kz» = дашборды+хосты+окно+лимит ядер одним словом):
# по умолчанию config/zabbix-contours.toml (образец config/zabbix-contours.example.toml).
ZABBIX_CONTOURS_CONFIG=

# --- Карты структуры хранения (storage_map.py): таблица СУБД ↔ объект 1С ---
# Каталог карт по базам (index.json + <База>.csv). Импорт выгрузки:
#   python scripts/storage_map.py import <файл.xls|csv> --base <ИмяБазы>
# Если задан — perf-отчёт Zabbix сам расшифровывает таблицы в SQL-уликах.
# Без переменной берётся <репозиторий>/data/storage_maps, если существует
# (локализации могут зашивать карты прямо в свой репозиторий).
ONEC_STORAGE_MAPS_DIR=

# --- Prometheus (опционально, если метрики 1С отдаёт экспортер) ---
PROMETHEUS_URL=

# --- Jira / Confluence (atlassian.py) ---
# Server/DC: только *_PAT (Bearer): профиль → Personal Access Tokens (отдельно Jira и Confluence).
# Cloud: дополнительно *_USER (email) → Basic user:token.
JIRA_URL=
JIRA_PAT=
# JIRA_USER=
CONFLUENCE_URL=
CONFLUENCE_PAT=
# CONFLUENCE_USER=
