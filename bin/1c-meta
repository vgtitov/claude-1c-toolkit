#!/usr/bin/env python3
"""1c-meta — headless CLI редактирования метаданных 1С (Конфигуратор-XML).

Подкоманды соответствуют операциям onec_metadata/ops. Ошибка предусловия
(объект не найден, дубль) — exit 2 с сообщением в stderr; файлы не меняются.
"""
import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from onec_metadata.formats.detect import detect_format, UnknownFormatError  # noqa: E402
from onec_metadata.ops import OpPreconditionError  # noqa: E402


def build_parser() -> argparse.ArgumentParser:
    ap = argparse.ArgumentParser(prog="1c-meta")
    sub = ap.add_subparsers(dest="cmd", required=True)

    d = sub.add_parser("detect", help="определить формат дерева исходников")
    d.add_argument("root")

    t = sub.add_parser("template", help="операции с макетами печатных форм")
    tsub = t.add_subparsers(dest="tcmd", required=True)
    tac = tsub.add_parser("add-column")
    tac.add_argument("file")
    tac.add_argument("--after", required=True, help="заголовок колонки-якоря")
    tac.add_argument("--header", required=True, help="заголовок новой колонки")
    tac.add_argument("--parameter", required=True, help="имя параметра данных")

    s = sub.add_parser("scd", help="операции со схемой компоновки данных")
    ssub = s.add_subparsers(dest="scmd", required=True)
    saf = ssub.add_parser("add-field")
    saf.add_argument("file")
    saf.add_argument("--dataset", required=True)
    saf.add_argument("--field", required=True)
    saf.add_argument("--data-path", required=True)
    saf.add_argument("--title", required=True)
    sgq = ssub.add_parser("get-query")
    sgq.add_argument("file")
    sgq.add_argument("--dataset", required=True)
    ssq = ssub.add_parser("set-query")
    ssq.add_argument("file")
    ssq.add_argument("--dataset", required=True)
    ssq.add_argument("--from-file", required=True)

    a = sub.add_parser("attr", help="реквизиты объектов метаданных")
    asub = a.add_subparsers(dest="acmd", required=True)
    aa = asub.add_parser("add")
    aa.add_argument("file")
    aa.add_argument("--name", required=True)
    aa.add_argument("--type", dest="type_ref", required=True)
    aa.add_argument("--synonym", required=True)

    c = sub.add_parser(
        "child", help="дочерние элементы: Dimension/Resource/Attribute/EnumValue")
    csub = c.add_subparsers(dest="ccmd", required=True)
    ca = csub.add_parser("add")
    ca.add_argument("file")
    ca.add_argument("--kind", required=True,
                    help="Attribute|Dimension|Resource|EnumValue|TabularSection|"
                         "Command|AddressingAttribute")
    ca.add_argument("--name", required=True)
    ca.add_argument("--synonym", required=True)
    ca.add_argument("--type", dest="type_ref",
                    help="обязателен для типизированных видов")
    ca.add_argument("--parent",
                    help="имя табличной части — добавить элемент внутрь неё")
    ca.add_argument("--donor",
                    help="объект-донор образца (если в целевом нет образца вида)")

    sb = sub.add_parser("subsystem", help="состав подсистемы (командный интерфейс)")
    sbsub = sb.add_subparsers(dest="sbcmd", required=True)
    sbc = sbsub.add_parser("add-content")
    sbc.add_argument("file")
    sbc.add_argument("--ref", required=True,
                     help="ссылка объекта вида Тип.Имя (напр. Document.Заказ)")

    sp = sub.add_parser("set-property",
                        help="изменить существующее скалярное свойство объекта/реквизита")
    sp.add_argument("file")
    sp.add_argument("--name", required=True, help="имя свойства (тег)")
    sp.add_argument("--value", required=True, help="новое значение")
    sp.add_argument("--attribute", help="имя реквизита (иначе — свойство объекта)")

    fm = sub.add_parser("form", help="правка управляемых форм")
    fmsub = fm.add_subparsers(dest="fmcmd", required=True)
    fma = fmsub.add_parser("add-attribute")
    fma.add_argument("file", help="путь к Forms/<Имя>/Ext/Form.xml (или Form.form EDT)")
    fma.add_argument("--name", required=True, help="имя реквизита формы")
    fma.add_argument("--type", dest="type_ref", required=True, help="тип реквизита")
    fmf = fmsub.add_parser("add-field")
    fmf.add_argument("file", help="путь к Forms/<Имя>/Ext/Form.xml (Конфигуратор)")
    fmf.add_argument("--name", required=True, help="имя элемента (InputField)")
    fmf.add_argument("--data-path", required=True, help="привязка данных, напр. Объект.Артикул")

    et = sub.add_parser("edit-type",
                        help="задать/сменить тип реквизита/измерения/ресурса или самого объекта")
    et.add_argument("file")
    et.add_argument("--attribute", "--member", dest="attribute", default=None,
                    help="имя реквизита/измерения/ресурса; без него — тип самого объекта "
                         "(параметр сеанса/константа/определяемый тип)")
    et.add_argument("--type", dest="type_ref", required=True,
                    help="новый тип (напр. cfg:CatalogRef.Товары / xs:string / String)")
    et.add_argument("--length", type=int,
                    help="длина строкового типа (строит квалификатор, если его нет)")
    et.add_argument("--precision", type=int, help="точность числа (Digits/precision)")
    et.add_argument("--scale", type=int, help="масштаб числа (FractionDigits/scale)")

    rl = sub.add_parser("role", help="права роли (Rights.xml)")
    rlsub = rl.add_subparsers(dest="rlcmd", required=True)
    rg = rlsub.add_parser("grant")
    rg.add_argument("file", help="путь к Roles/<Роль>/Ext/Rights.xml")
    rg.add_argument("--ref", required=True,
                    help="ссылка объекта вида Тип.Имя (напр. Catalog.Товары)")
    rg.add_argument("--right", required=True,
                    help="имя права (Read/View/Insert/Update/Delete/…)")
    rg.add_argument("--value", choices=["true", "false"], default="true",
                    help="значение права (по умолчанию true)")

    return ap


def main() -> None:
    ns = build_parser().parse_args()
    try:
        if ns.cmd == "detect":
            print(detect_format(Path(ns.root)).name)
        elif ns.cmd == "template":
            from onec_metadata.ops.template_add_column import add_column
            add_column(Path(ns.file), ns.after, ns.header, ns.parameter)
        elif ns.cmd == "scd":
            from onec_metadata.ops import scd
            if ns.scmd == "add-field":
                scd.add_field(Path(ns.file), ns.dataset, ns.field,
                              ns.data_path, ns.title)
            elif ns.scmd == "get-query":
                print(scd.get_dataset_query(Path(ns.file), ns.dataset))
            else:
                scd.set_dataset_query(
                    Path(ns.file), ns.dataset,
                    Path(ns.from_file).read_text(encoding="utf-8"))
        elif ns.cmd == "attr":
            from onec_metadata.ops.attribute_add import add_attribute
            add_attribute(Path(ns.file), ns.name, ns.type_ref, ns.synonym)
        elif ns.cmd == "child":
            from onec_metadata.ops.add_child import add_child
            add_child(Path(ns.file), ns.kind, ns.name, ns.synonym,
                      ns.type_ref, ns.parent,
                      Path(ns.donor) if ns.donor else None)
        elif ns.cmd == "subsystem":
            from onec_metadata.ops.subsystem import add_content
            add_content(Path(ns.file), ns.ref)
        elif ns.cmd == "role":
            from onec_metadata.ops.role import grant_right
            grant_right(Path(ns.file), ns.ref, ns.right, ns.value == "true")
        elif ns.cmd == "set-property":
            from onec_metadata.ops.set_property import set_property
            set_property(Path(ns.file), ns.name, ns.value, ns.attribute)
        elif ns.cmd == "edit-type":
            from onec_metadata.ops.edit_type import edit_type
            edit_type(Path(ns.file), ns.attribute, ns.type_ref,
                      ns.length, ns.precision, ns.scale)
        elif ns.cmd == "form":
            if ns.fmcmd == "add-attribute":
                from onec_metadata.ops.form import add_attribute as form_add_attr
                form_add_attr(Path(ns.file), ns.name, ns.type_ref)
            else:
                from onec_metadata.ops.form import add_field as form_add_field
                form_add_field(Path(ns.file), ns.name, ns.data_path)
    except (OpPreconditionError, UnknownFormatError) as e:
        print(f"Ошибка предусловия: {e}", file=sys.stderr)
        sys.exit(2)


if __name__ == "__main__":
    main()
