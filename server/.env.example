# Пример окружения для центрального onec-code MCP (docker-compose). Скопируй в .env и заполни.
# .env в репозиторий НЕ коммитится (см. .gitignore).

# Каталог с клонами конфигураций/расширений 1С на хосте (монтируется в контейнер read-only).
ONEC_SRC_DIR=/path/to/1c-clones

# Общий секрет авторизации. Клиент шлёт его как заголовок: Authorization: Bearer <значение>.
# Сгенерируй случайный, например:  openssl rand -hex 32
ONEC_BEARER_TOKEN=change-me-to-a-long-random-string

# Порт, на котором центр публикуется наружу (через Caddy). По умолчанию 8000.
ONEC_PUBLIC_PORT=8000

# (необязательно) Свой конфиг слоёв/scope/режимов. По умолчанию ../config/layers.example.toml.
# Путь относителен каталога server/ (где лежит docker-compose.yml).
# ONEC_LAYERS_CONFIG=../config/layers.local.toml

# (необязательно) Активный профиль/режим из конфига слоёв (секция [profiles.<имя>]).
# ONEC_PROFILE=rb

# --- onec-ops (MCP эксплуатации: ТЖ/ЖР/Apdex/диагностика/Zabbix/Prometheus) ---
# Порт onec-ops наружу (через Caddy, та же bearer-аутентификация). По умолчанию 8001.
ONEC_OPS_PUBLIC_PORT=8001
# Каталог(и) логов 1С (технологический журнал / выгрузки ЖР) на хосте — read-only вход onec-ops.
ONEC_TJ_DIR=/path/to/1c-logs
# (необязательно) Адаптеры мониторинга — read-only доступ; ПУСТО = выключено. Секреты только здесь, не в git.
# ZABBIX_URL=https://zabbix.example/api_jsonrpc.php
# ZABBIX_TOKEN=
# PROMETHEUS_URL=http://prometheus.example:9090
