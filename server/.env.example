# Пример окружения для центрального erp-1c MCP (docker-compose). Скопируй в .env и заполни.
# .env в репозиторий НЕ коммитится (см. .gitignore).

# Каталог с клонами конфигураций/расширений 1С на хосте (монтируется в контейнер read-only).
ONEC_SRC_DIR=/path/to/1c-clones

# Общий секрет авторизации. Клиент шлёт его как заголовок: Authorization: Bearer <значение>.
# Сгенерируй случайный, например:  openssl rand -hex 32
ERP_BEARER_TOKEN=change-me-to-a-long-random-string

# Порт, на котором центр публикуется наружу (через Caddy). По умолчанию 8000.
ERP_PUBLIC_PORT=8000

# (необязательно) Свой конфиг слоёв/scope/режимов. По умолчанию ../config/layers.example.toml.
# Путь относителен каталога server/ (где лежит docker-compose.yml).
# ONEC_LAYERS_CONFIG=../config/layers.local.toml

# (необязательно) Активный профиль/режим из конфига слоёв (секция [profiles.<имя>]).
# ONEC_PROFILE=rb
