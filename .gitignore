# Секреты — НИКОГДА в репозиторий
*token*
!set_token.ps1
!set_token.sh
!set_token.cmd
*secret*
*.key
.env
.env.*
!.env.example
credentials*.json
# локализация с именами хостов/дашбордов контуров — в свой командный репозиторий, не сюда
config/zabbix-contours.toml

# Локальное окружение
# .mcp.json — ЛОКАЛЬНЫЙ/генерируемый (onboard+switch_source localize его под контур: Docker-central/локальные пути).
# Источник истины — core/mcp/servers.json (коммитится). Генерация: sh build.sh. НЕ коммитить .mcp.json (иначе конфликт с локальным на настроенных машинах).
.mcp.json
src/
# ...но исходники расширений toolkit (напр. extensions/ai_debug/src) — это КОД, он отслеживается
!extensions/**/src/
!extensions/**/src/**
mcp-server.log
*.log

__pycache__/
*.pyc
.venv/
.DS_Store
.pytest_cache/
